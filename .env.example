# OOBE × Ace Data Cloud — Autonomous Agent Configuration
# Copy to .env and fill in your values

# Solana wallet (for x402 payments via Ace Data Cloud)
SOLANA_PRIVATE_KEY_BASE58=

# Ace Data Cloud (optional — x402 auto-creates account)
ACEDATACLOUD_API_TOKEN=

# Synapse Agent Protocol
SYNAPSE_API_KEY=
SYNAPSE_ENDPOINT=https://staging.oobeprotocol.ai:8080/rpc

# Agent identity
AGENT_NAME=AtlasNexusDataIntel
AGENT_DESCRIPTION="Autonomous crypto data intelligence agent — real-time market analysis, data cleaning & validation, AI-powered reporting"
