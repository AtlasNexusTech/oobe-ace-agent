# Atlas Nexus — Autonomous Data Intelligence Agent
# OOBE Synapse × Ace Data Cloud × SAP

# Solana Wallet (required for SAP + x402)
# Option 1: Path to keypair JSON file
SOLANA_KEYPAIR_PATH=
# Option 2: Base58-encoded private key
SOLANA_PRIVATE_KEY_BASE58=

# OOBE Protocol API Key (required for Synapse Client SDK)
OOBE_API_KEY=

# Synapse RPC endpoint (EU mainnet default)
SYNAPSE_ENDPOINT=https://staging.oobeprotocol.ai:8080/rpc

# Ace Data Cloud MCP endpoint
ACE_MCP_ENDPOINT=https://platform.acedata.cloud/mcp/sse

# Demo configuration
DEMO_QUERY=Solana DeFi ecosystem trends 2025
